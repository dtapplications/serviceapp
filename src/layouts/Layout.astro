---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'ТИМ КАР', description = 'Специализиран сервиз за хидравлични рейки, помпи и авторемонт. Ремонт, не замяна.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      :root{--accent:#DD6B1E;--bg:#F4F1EA;--panel:#17181A;--line:#E4DFD3;--text:#191A1C;--text-muted:#6E6A62}
      html,body{margin:0;padding:0}
      html{background:#17181A}
      body{background:#F4F1EA;overflow-x:hidden}
      header{position:sticky;top:0;z-index:50;background:#17181A;border-bottom:1px solid rgba(255,255,255,.07);color:#EDEAE2}
      .header-inner{max-width:1280px;margin:0 auto;padding:0 32px;height:72px;display:flex;align-items:center;gap:24px}
    </style>
    <base href={import.meta.env.BASE_URL} />
    <meta name="description" content={description} />
    <title>{title} | ТИМ КАР</title>
    <link rel="icon" href={`${base}favicon.png`} type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href={base} class="logo">
          <img src={`${base}images/logo.png`} alt="ТИМ КАР" class="logo-img" />
        </a>
        <button class="nav-toggle" id="navToggle">☰</button>
        <nav id="mainNav">
          <ul>
            <li><a href={base}>Начало</a></li>
            <li><a href={`${base}za-nas`}>За нас</a></li>
            <li>
              <a href={`${base}uslugi`}>Услуги ▾</a>
              <ul>
                <li class="dropdown-heading"><a href={`${base}remont-reyki`}>Ремонт на рейки</a></li>
                <li><a href={`${base}remont-reyki/hidravlichni`}>- Хидравлични рейки</a></li>
                <li><a href={`${base}remont-reyki/eps`}>- EPS рейки</a></li>
                <li><a href={`${base}remont-reyki/mehanchni`}>- Механични рейки</a></li>
                <li class="dropdown-divider"></li>
                <li class="dropdown-heading"><a href={`${base}remont-pompi`}>Ремонт на помпи</a></li>
                <li><a href={`${base}remont-pompi/hidravlichni`}>- Хидравлични помпи</a></li>
                <li><a href={`${base}remont-pompi/zobchati`}>- Зъбчати помпи</a></li>
                <li><a href={`${base}remont-pompi/butaleni`}>- Бутални помпи</a></li>
                <li class="dropdown-divider"></li>
                <li><a href={`${base}uslugi/hidravlichni-tsilindri`}>Хидравлични цилиндри</a></li>
                <li><a href={`${base}uslugi/hidromotor`}>Хидромотор</a></li>
                <li><a href={`${base}uslugi/reduktori`}>Редуктори</a></li>
                <li class="dropdown-divider"></li>
                <li class="dropdown-heading"><a href={`${base}uslugi/avtomobilno-obsluzhvane`}>Авторемонт</a></li>
                <li><a href={`${base}uslugi/sprachki`}>- Спирачна система</a></li>
                <li><a href={`${base}uslugi/hodova`}>- Ходова и окачване</a></li>
                <li><a href={`${base}uslugi/saediniteli`}>- Съединители</a></li>
                <li><a href={`${base}uslugi/angrenajni-remaci`}>- Ангренажни ремъци</a></li>
                <li><a href={`${base}uslugi/diagnostika`}>- Диагностика и геометрия</a></li>
              </ul>
            </li>
            <li><a href={`${base}garantsiya`}>Гаранция</a></li>
            <li><a href={`${base}polezno`}>Полезно</a></li>
            <li><a href={`${base}kontakti`}>Контакти</a></li>
          </ul>
        </nav>
        <div class="header-contacts">
<a href="https://www.facebook.com/timcar" target="_blank" aria-label="Facebook" class="header-fb">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="tel:0888308666" class="header-phone">0888 308 666</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <div class="footer-logo">
              <img src={`${base}images/logo.png`} alt="ТИМ КАР" style="height:52px; width:auto;" />
            </div>
            <p>Сервиз за хидравлични рейки, помпи и авторемонт. Бърза диагностика и качествен ремонт с гаранция.</p>
          </div>
          <div class="footer-col">
            <h4>Услуги</h4>
            <ul>
              <li><a href={`${base}remont-reyki`}>Ремонт на рейки</a></li>
              <li><a href={`${base}remont-pompi`}>Ремонт на помпи</a></li>
              <li><a href={`${base}uslugi/hidravlichni-tsilindri`}>Цилиндри и мотори</a></li>
              <li><a href={`${base}uslugi/avtomobilno-obsluzhvane`}>Авторемонт</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Компания</h4>
            <ul>
              <li><a href={`${base}za-nas`}>За нас</a></li>
              <li><a href={`${base}garantsiya`}>Гаранция</a></li>
              <li><a href={`${base}polezno`}>Полезно</a></li>
              <li><a href={`${base}kontakti`}>Контакти</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Контакти</h4>
            <ul>
              <li><a href="tel:0888308666" style="color:#EDEAE2; font-family:'JetBrains Mono',monospace;">0888 308 666</a></li>
              <li><a href="mailto:office@timcar.com">office@timcar.com</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">© 2026 ТИМ КАР · Всички права запазени</div>
      </div>
    </footer>

    <script>
      function initNav() {
        const toggle = document.getElementById('navToggle');
        const nav = document.getElementById('mainNav');
        toggle?.addEventListener('click', () => nav?.classList.toggle('open'));

        // Mobile: tap on a link that has a submenu → toggle it instead of navigating
        document.querySelectorAll('nav ul li > a').forEach(link => {
          link.addEventListener('click', (e) => {
            // Only intercept on narrow screens (mobile nav is open)
            if (window.innerWidth > 900) return;
            const li = link.parentElement;
            if (li?.querySelector('ul')) {
              e.preventDefault();
              li.classList.toggle('open');
            }
          });
        });
      }
      document.addEventListener('astro:page-load', initNav);
    </script>
  </body>
</html>
