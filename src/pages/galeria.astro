---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
const base = import.meta.env.BASE_URL;

const glob = import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/*.{jpg,webp}', { eager: true });
const images = Object.values(glob).map(m => m.default);
---

<Layout title="Галерия" description="Снимки от сервиза на ТИМ КАР - работилница, оборудване и ремонти на хидравлични рейки, помпи и автомобили в София.">
  <div class="page-hero">
    <div class="container">
      <h1>Галерия</h1>
      <p>Снимки от сервиза - работилница и ремонти</p>
    </div>
  </div>
  <div class="breadcrumb">
    <div class="container"><a href={base}>Начало</a> / Галерия</div>
  </div>

  <section>
    <div class="container">
      <div class="gallery-grid">
        {images.map((img, i) => (
          <button class="gallery-thumb" data-index={i} aria-label="Отвори снимка">
            <Image
              src={img}
              alt={`Сервиз ТИМ КАР - снимка ${i + 1}`}
              width={480}
              height={360}
              loading="lazy"
              style="width:100%; height:100%; object-fit:cover; display:block;"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <dialog id="lightbox" aria-label="Преглед на снимка">
    <button id="lb-close" aria-label="Затвори">✕</button>
    <button id="lb-prev" aria-label="Предишна">‹</button>
    <button id="lb-next" aria-label="Следваща">›</button>
    <img id="lb-img" src="" alt="" />
  </dialog>
</Layout>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 8px;
  }

  .gallery-thumb {
    aspect-ratio: 4/3;
    overflow: hidden;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    background: var(--panel);
    display: block;
    transition: opacity 0.2s;
  }
  .gallery-thumb:hover { opacity: 0.85; }

  #lightbox {
    border: none;
    background: rgba(0,0,0,.92);
    padding: 0;
    max-width: 100vw;
    max-height: 100dvh;
    width: 100vw;
    height: 100dvh;
    display: none;
    align-items: center;
    justify-content: center;
  }
  #lightbox[open] { display: flex; }
  #lightbox::backdrop { background: rgba(0,0,0,.85); }

  #lb-img {
    max-width: 92vw;
    max-height: 88dvh;
    object-fit: contain;
    display: block;
  }

  #lb-close, #lb-prev, #lb-next {
    position: fixed;
    background: rgba(255,255,255,.12);
    border: none;
    color: #fff;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    z-index: 10;
  }
  #lb-close, #lb-prev, #lb-next { line-height: 1; }
  #lb-close:hover, #lb-prev:hover, #lb-next:hover { background: rgba(255,255,255,.25); }

  #lb-close { top: 20px; right: 20px; width: 44px; height: 44px; font-size: 18px; }
  #lb-prev  { left: 16px; top: 50%; transform: translateY(-50%); width: 52px; height: 52px; font-size: 32px; }
  #lb-next  { right: 16px; top: 50%; transform: translateY(-50%); width: 52px; height: 52px; font-size: 32px; }

  @media (max-width: 600px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 4px; }
    #lb-prev { left: 6px; }
    #lb-next { right: 6px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-thumb'));
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const img = document.getElementById('lb-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lb-close')!;
    const prevBtn = document.getElementById('lb-prev')!;
    const nextBtn = document.getElementById('lb-next')!;

    if (!dialog || !thumbs.length) return;

    let current = 0;

    function getSrc(thumb: HTMLButtonElement): string {
      const i = thumb.querySelector('img');
      return i?.src ?? '';
    }

    function open(index: number) {
      current = index;
      img.src = getSrc(thumbs[current]);
      img.alt = thumbs[current].querySelector('img')?.alt ?? '';
      dialog.showModal();
      document.body.style.overflow = 'hidden';
    }

    function close() {
      dialog.close();
      document.body.style.overflow = '';
    }

    function go(dir: number) {
      current = (current + dir + thumbs.length) % thumbs.length;
      img.src = getSrc(thumbs[current]);
      img.alt = thumbs[current].querySelector('img')?.alt ?? '';
    }

    thumbs.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', () => go(-1));
    nextBtn.addEventListener('click', () => go(1));
    dialog.addEventListener('click', (e) => { if (e.target === dialog) close(); });
    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') go(-1);
      if (e.key === 'ArrowRight') go(1);
    });
  });
</script>
